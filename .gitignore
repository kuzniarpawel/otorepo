# local dev tooling (Claude preview server; serve.ps1 has an absolute local path)
.claude/

# design mockups / screenshots (root only — must NOT match Android launcher icons under android/)
/*.png

# prototype scratch files (not part of the app)
proto_ui.html
semont_2d.html

# --- Node / Capacitor / Vite ---
node_modules/

# Vite build output (generated from otorepo.html / późniejsze src/)
dist/

# generated web root — copied from otorepo.html by `npm run copy:web`
www/

# app signing keys & secrets — NEVER commit these
*.keystore
*.jks
keystore.properties

# stray Windows shortcuts
*.lnk

# raw phone screenshots / Play store upload assets (not repo content)
Screenshot_*
