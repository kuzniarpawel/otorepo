<!-- Foreground adaptive-icon OTOREPO: logo "ucho/ślimak" z otorepo.html (topbar .mark).
     Ścieżka w układzie 24x24 (jak w SVG aplikacji), wyśrodkowana w 108dp przez group scale+translate,
     w strefie bezpiecznej (~66dp). Kolor = --primary (#4FC9E8) na tle --bg (ic_launcher_background).
     Regulacja rozmiaru/pozycji: zmień scaleX/scaleY i translateX/translateY w <group>. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="3.6"
        android:scaleY="3.6"
        android:translateX="9"
        android:translateY="7.2">
        <path
            android:pathData="M5,13 c0,-5 4,-8 7.5,-8 S20,7.5 20,11 c0,3 -2.5,4 -2.5,6.5 S16,21 14,21 s-2,-2 -2,-3.5 S10.5,15 9,14 s-4,0.5 -4,-1 Z"
            android:strokeColor="#4FC9E8"
            android:strokeWidth="1.6"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000" />
    </group>
</vector>
